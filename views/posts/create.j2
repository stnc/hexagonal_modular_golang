{% extends "layouts/main.j2" %}
{% block content %}
<div class="card shadow-sm">
  <div class="card-body">
    <h1 class="h3 mb-4">{{ PageTitle  }}</h1>
    {% if ErrorGeneral %}
    <div class="alert alert-danger">{{ ErrorGeneral }}</div>
    {% endif %}
    <form action="{{ FormAction }}" method="post" class="row g-3">
      <input type="hidden" name="_csrf" value="{{ CsrfToken }}">

      <div class="col-12">
        <label class="form-label">Title</label>
        <input type="text" name="title" class="form-control {% if ErrorTitle %}is-invalid{% endif %}" value="{{ Post.Title }}" placeholder="post title" />
        {% if ErrorTitle %}<div class="invalid-feedback">{{ ErrorTitle }}</div>{% endif %}
      </div>
      <div class="col-12">
        <label class="form-label">Content</label>
        <textarea name="content" class="form-control {% if ErrorContent %}is-invalid{% endif %}" rows="6" placeholder="post content">{{ Post.Content }}</textarea>
        {% if ErrorContent %}<div class="invalid-feedback">{{ ErrorContent }}</div>{% endif %}
      </div>
      <div class="col-12 d-flex gap-2">
        <button type="submit" class="btn btn-primary">{{ SubmitLabel }}</button>
        <a href="/web/posts/list" class="btn btn-outline-secondary">Cancel</a>
      </div>
    </form>
  </div>
</div>
{% endblock %}
