{% extends "layouts/main.j2" %}
{% block content %}
<div class="card shadow-sm">
  <div class="card-body">
    <h1 class="h3 mb-4">{{ PageTitle or Title }}</h1>
    <div class="mb-3">
      <strong>Post ID:</strong> {{ PostID }}
    </div>
    <div class="mb-3">
      <strong>User ID:</strong> {{ UserID }}
    </div>
    <div class="mb-3">
      <strong>Title:</strong> {{ Title }}
    </div>
    <div class="mb-4">
      <strong>Content:</strong>
      <div class="mt-2 p-3 border rounded bg-light">{{ Content }}</div>
    </div>
    <div class="d-flex gap-2">
      <a href="/web/post/{{ PostID }}/edit" class="btn btn-outline-secondary">Edit</a>
      <form action="/web/post/{{ PostID }}/delete" method="post" class="d-inline" onsubmit="return confirm('Silinsin mi?');">
        <input type="hidden" name="_csrf" value="{{ CsrfToken }}">
        <button type="submit" class="btn btn-outline-danger">Delete</button>
      </form>
      <a href="/web/posts/list" class="btn btn-primary">List</a>
    </div>
  </div>
</div>
{% endblock %}
